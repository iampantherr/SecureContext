# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL password (REQUIRED — change before deploying)
POSTGRES_PASSWORD=changeme_use_a_strong_password

# API server authentication key (REQUIRED — change before deploying)
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ZC_API_KEY=changeme_use_a_strong_key

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=securecontext
POSTGRES_USER=scuser
POSTGRES_PORT=5432

# ─── API Server ────────────────────────────────────────────────────────────────
# Port the API server listens on (inside container: always 3099)
SC_API_PORT=3099

# CORS origins (comma-separated). Use "*" for open access (dev only).
# ZC_API_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Log level: trace | debug | info | warn | error
# ZC_API_LOG_LEVEL=warn

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_MODEL=nomic-embed-text

# GPU mode for Ollama: auto | nvidia | amd | cpu
# "auto" detects your GPU at start.ps1 launch time.
ZC_GPU_MODE=auto

# CPU threads (only used when ZC_GPU_MODE=cpu)
OLLAMA_NUM_THREADS=4

# ─── MCP Plugin remote mode ────────────────────────────────────────────────────
# Set these in each agent's environment to use the API server instead of local SQLite.
# ZC_API_URL=http://localhost:3099
# ZC_API_KEY=<same as above>
